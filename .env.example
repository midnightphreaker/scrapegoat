# Embedding Model Configuration
# Optional: Format is "provider:model_name" or just "model_name" for OpenAI (default)
# Examples:
#   - openai:text-embedding-3-small (default if no provider specified)
#   - vertex:text-embedding-004 (Google Cloud Vertex AI)
#   - gemini:gemini-embedding-exp-03-07 (Google Generative AI)
#   - aws:amazon.titan-embed-text-v1
#   - microsoft:text-embedding-ada-002
SCRAPEGOAT_EMBEDDING_MODEL=

# PostHog Analytics Configuration (Optional)
# Get your API key from: https://app.posthog.com/project/settings
# Leave empty to disable analytics completely
POSTHOG_API_KEY=

# OpenAI Provider Configuration (Default)
# Required for OpenAI provider or as fallback
OPENAI_API_KEY=your-key-here
# Optional: Your OpenAI Organization ID
OPENAI_ORG_ID=
# Optional: Custom base URL for OpenAI-compatible APIs (e.g., Ollama, Azure OpenAI)
OPENAI_API_BASE=

# Google Cloud Vertex AI Configuration
# Required for vertex provider: Path to service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-key.json

# Google Generative AI (Gemini) Configuration
# Required for gemini provider: Google API key
GOOGLE_API_KEY=your-google-api-key

# AWS Bedrock Configuration
# Required for aws provider
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
# Optional: Use BEDROCK_AWS_REGION instead of AWS_REGION if needed
# BEDROCK_AWS_REGION=us-east-1

# Azure OpenAI Configuration
# Required for microsoft provider
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_API_INSTANCE_NAME=your-instance
AZURE_OPENAI_API_DEPLOYMENT_NAME=your-deployment
AZURE_OPENAI_API_VERSION=2024-02-01

# Optional: Specify a custom directory to store the SQLite database file (documents.db).
# If set, this path takes precedence over the default locations.
# Default behavior (if unset):
# 1. Uses './.store/' in the project root if it exists (legacy).
# 2. Falls back to OS-specific data directory (e.g., ~/Library/Application Support/scrapegoat on macOS).
# SCRAPEGOAT_STORE_PATH=/path/to/your/desired/storage/directory

# === Embedding Tuning ===
# Start conservative with local embedders and small-context models, then raise batch limits gradually.

# Embedding batching (app-level):
#   BATCH_SIZE = max chunks queued per embedding cycle (app controls batching logic).
#   BATCH_CHARS = max total characters per embedding request.
#   API_BATCH_SIZE = SDK-level batch size per single API call (OpenAI only).
#   If you increase BATCH_SIZE, you may also want to raise API_BATCH_SIZE for throughput.
# SCRAPEGOAT_EMBEDDINGS_BATCH_SIZE=${SCRAPEGOAT_EMBEDDINGS_BATCH_SIZE:-100}
# SCRAPEGOAT_EMBEDDINGS_BATCH_CHARS=${SCRAPEGOAT_EMBEDDINGS_BATCH_CHARS:-50000}

# Embedding provider settings:
# Strip newlines before embedding — recommended for most providers.
# SCRAPEGOAT_EMBEDDINGS_STRIP_NEW_LINES=${SCRAPEGOAT_EMBEDDINGS_STRIP_NEW_LINES:-true}
# SDK-level batch size per API call (OpenAI provider). Controls how many texts are sent
# in a single embedding API request. Larger values improve throughput but may hit rate limits.
# SCRAPEGOAT_EMBEDDINGS_API_BATCH_SIZE=${SCRAPEGOAT_EMBEDDINGS_API_BATCH_SIZE:-512}
# Allow truncating embeddings to the target dimension (Gemini provider).
# SCRAPEGOAT_EMBEDDINGS_ALLOW_TRUNCATE=${SCRAPEGOAT_EMBEDDINGS_ALLOW_TRUNCATE:-true}

# Timeouts:
# SCRAPEGOAT_EMBEDDINGS_REQUEST_TIMEOUT_MS=${SCRAPEGOAT_EMBEDDINGS_REQUEST_TIMEOUT_MS:-30000}
# SCRAPEGOAT_EMBEDDINGS_INIT_TIMEOUT_MS=${SCRAPEGOAT_EMBEDDINGS_INIT_TIMEOUT_MS:-30000}

# === Search Tuning ===

# Vector search weight in hybrid scoring (multiplied with vector similarity score).
# SCRAPEGOAT_SEARCH_WEIGHT_VEC=${SCRAPEGOAT_SEARCH_WEIGHT_VEC:-1}
# Full-text search weight in hybrid scoring (multiplied with FTS rank score).
# SCRAPEGOAT_SEARCH_WEIGHT_FTS=${SCRAPEGOAT_SEARCH_WEIGHT_FTS:-1}
# Vector result overfetch multiplier — fetches vectorMultiplier × limit candidates
# before re-ranking, to improve recall.
# SCRAPEGOAT_SEARCH_VECTOR_MULTIPLIER=${SCRAPEGOAT_SEARCH_VECTOR_MULTIPLIER:-10}
# FTS result overfetch multiplier — fetches overfetchFactor × limit candidates
# before re-ranking, to improve recall.
# SCRAPEGOAT_SEARCH_OVERFETCH_FACTOR=${SCRAPEGOAT_SEARCH_OVERFETCH_FACTOR:-2}
# RRF (Reciprocal Rank Fusion) smoothing constant. Higher values dampen the
# effect of individual rankings. Minimum: 1.
# SCRAPEGOAT_SEARCH_RRF_K=${SCRAPEGOAT_SEARCH_RRF_K:-60}

# === Splitter Tuning ===

# Minimum chunk body size in characters — smaller chunks are merged up.
# SCRAPEGOAT_SPLITTER_MIN_CHUNK_SIZE=${SCRAPEGOAT_SPLITTER_MIN_CHUNK_SIZE:-500}
# Soft chunk body target in characters — splitter aims for this size.
# SCRAPEGOAT_SPLITTER_PREFERRED_CHUNK_SIZE=${SCRAPEGOAT_SPLITTER_PREFERRED_CHUNK_SIZE:-1500}
# Hard chunk body limit in characters — chunks never exceed this.
# SCRAPEGOAT_SPLITTER_MAX_CHUNK_SIZE=${SCRAPEGOAT_SPLITTER_MAX_CHUNK_SIZE:-5000}

# === Scraping Throughput ===

# Concurrent page fetches per scrape job.
# SCRAPEGOAT_SCRAPER_MAX_CONCURRENCY=${SCRAPEGOAT_SCRAPER_MAX_CONCURRENCY:-3}

# PostgreSQL Database
DATABASE_URL=postgresql://docs:docs@localhost:5432/docs
VECTOR_DIMENSION=1536

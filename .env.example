# =============================================================================
# ScrapeGoat Configuration
# =============================================================================
# Copy this file to .env and configure before starting ScrapeGoat:
#   cp .env.example .env
#
# All values shown as commented defaults match the application defaults.
# Uncomment and modify only the settings you need to change.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — PostgreSQL
# -----------------------------------------------------------------------------
# Connection URL for PostgreSQL (used by all ScrapeGoat services).
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# In docker-compose.postgres.yml, this is auto-generated from the DB_* vars below.
# For standalone docker-compose.yml or manual setup, set this explicitly.
# SCRAPEGOAT_DB_URL=

# PostgreSQL credentials (used by docker-compose.postgres.yml to configure the
# database container AND auto-build the connection URL above).
# SCRAPEGOAT_DB_USER=scrapegoat
# SCRAPEGOAT_DB_PASSWORD=scrapegoat
# SCRAPEGOAT_DB_NAME=scrapegoat

# PostgreSQL host binding (address and port exposed on the host).
# SCRAPEGOAT_DB_HOST_ADDRESS=localhost
# SCRAPEGOAT_DB_HOST_PORT=5432

# PostgreSQL image tag (pgvector variant).
# SCRAPEGOAT_PG_VERSION=pg16

# Vector embedding dimension — must match your embedding model's output size.
# Common values: 1536 (OpenAI text-embedding-3-small), 1024, 768.
# Changing this after initial setup will invalidate existing embeddings.
# SCRAPEGOAT_DB_VECTOR_SIZE=1536

# Optional: Store ScrapeGoat data in a custom directory.
# Default: OS-specific data directory (e.g., ~/.local/share/scrapegoat on Linux).
# SCRAPEGOAT_STORE_PATH=/path/to/storage/directory

# -----------------------------------------------------------------------------
# Network — Service Host Bindings
# -----------------------------------------------------------------------------
# The IP address and port each service binds to on the host.
# Use 0.0.0.0 as the address to bind to all interfaces, or a specific IP
# (e.g., 192.168.1.100) to restrict access.
# SCRAPEGOAT_PORT=6280
# PORT=6280
# SCRAPEGOAT_WEB_PORT=6281
# SCRAPEGOAT_WORKER_HOST_ADDRESS=localhost
# SCRAPEGOAT_WORKER_HOST_PORT=8080
# SCRAPEGOAT_MCP_HOST_ADDRESS=localhost
# SCRAPEGOAT_MCP_HOST_PORT=6280
# SCRAPEGOAT_WEB_HOST_ADDRESS=localhost
# SCRAPEGOAT_WEB_HOST_PORT=6281

# Optional: Container image tag (defaults to "latest").
# SCRAPEGOAT_IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Resource Limits (Docker only)
# -----------------------------------------------------------------------------
# Memory limits per service. Format: <number><unit> where unit is B, K, M, or G.
# SCRAPEGOAT_WORKER_MEMORY_LIMIT=2G
# SCRAPEGOAT_WORKER_MEMORY_RESERVATION=1G
# SCRAPEGOAT_MCP_MEMORY_LIMIT=512M
# SCRAPEGOAT_MCP_MEMORY_RESERVATION=256M
# SCRAPEGOAT_WEB_MEMORY_LIMIT=1G
# SCRAPEGOAT_WEB_MEMORY_RESERVATION=512M

# -----------------------------------------------------------------------------
# Embedding Model
# -----------------------------------------------------------------------------
# Model used for vector search. Format: "provider:model_name" or just "model_name"
# for OpenAI (default provider). Leave empty to disable semantic search.
# Examples:
#   text-embedding-3-small         (OpenAI, default if OPENAI_API_KEY is set)
#   openai:nomic-embed-text        (Ollama or any OpenAI-compatible API)
#   vertex:text-embedding-004      (Google Cloud Vertex AI)
#   gemini:embedding-001           (Google Generative AI)
#   aws:amazon.titan-embed-text-v1 (AWS Bedrock)
# SCRAPEGOAT_EMBEDDING_MODEL=

# -----------------------------------------------------------------------------
# OpenAI Provider (Default)
# -----------------------------------------------------------------------------
# Required for OpenAI embeddings or any OpenAI-compatible API (e.g., Ollama).
# OPENAI_API_KEY=
# Optional: OpenAI Organization ID.
# OPENAI_ORG_ID=
# Custom base URL for OpenAI-compatible APIs (e.g., http://localhost:11434/v1 for Ollama).
# OPENAI_API_BASE=

# -----------------------------------------------------------------------------
# Google Cloud Vertex AI Provider
# -----------------------------------------------------------------------------
# Path to service account JSON key file.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-key.json

# -----------------------------------------------------------------------------
# Google Generative AI (Gemini) Provider
# -----------------------------------------------------------------------------
# Google API key.
# GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# AWS Bedrock Provider
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Azure OpenAI Provider
# -----------------------------------------------------------------------------
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_INSTANCE_NAME=
# AZURE_OPENAI_API_DEPLOYMENT_NAME=
# AZURE_OPENAI_API_VERSION=2024-02-01

# -----------------------------------------------------------------------------
# Embedding Tuning
# -----------------------------------------------------------------------------
# Start conservative with local embedders and small-context models.
# Increase batch limits gradually while watching latency and error rates.

# Application-level: max chunks queued per embedding cycle.
# SCRAPEGOAT_EMBEDDINGS_BATCH_SIZE=100
# Application-level: max total characters per embedding request.
# SCRAPEGOAT_EMBEDDINGS_BATCH_CHARS=50000
# SDK-level: batch size per single API call (OpenAI only).
# SCRAPEGOAT_EMBEDDINGS_API_BATCH_SIZE=512
# Strip newlines before embedding (recommended for most providers).
# SCRAPEGOAT_EMBEDDINGS_STRIP_NEW_LINES=true
# Allow truncating embeddings to target dimension (Gemini only).
# SCRAPEGOAT_EMBEDDINGS_ALLOW_TRUNCATE=true
# Per-request embedding API timeout in milliseconds.
# SCRAPEGOAT_EMBEDDINGS_REQUEST_TIMEOUT_MS=30000
# Initial test embedding timeout in milliseconds.
# SCRAPEGOAT_EMBEDDINGS_INIT_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Search Tuning
# -----------------------------------------------------------------------------
# Vector search weight in hybrid scoring.
# SCRAPEGOAT_SEARCH_WEIGHT_VEC=1
# Full-text search weight in hybrid scoring.
# SCRAPEGOAT_SEARCH_WEIGHT_FTS=1
# Vector result overfetch multiplier (higher = better recall, slower).
# SCRAPEGOAT_SEARCH_VECTOR_MULTIPLIER=10
# FTS result overfetch multiplier.
# SCRAPEGOAT_SEARCH_OVERFETCH_FACTOR=2
# RRF (Reciprocal Rank Fusion) smoothing constant. Minimum: 1.
# SCRAPEGOAT_SEARCH_RRF_K=60

# -----------------------------------------------------------------------------
# Splitter Tuning
# -----------------------------------------------------------------------------
# Minimum chunk body size in characters — smaller chunks are merged up.
# SCRAPEGOAT_SPLITTER_MIN_CHUNK_SIZE=500
# Soft chunk body target in characters.
# SCRAPEGOAT_SPLITTER_PREFERRED_CHUNK_SIZE=1500
# Hard chunk body limit in characters — chunks never exceed this.
# SCRAPEGOAT_SPLITTER_MAX_CHUNK_SIZE=5000

# -----------------------------------------------------------------------------
# Scraping Throughput
# -----------------------------------------------------------------------------
# Concurrent page fetches per scrape job.
# SCRAPEGOAT_SCRAPER_MAX_CONCURRENCY=3

# Maximum size in bytes for PDF/Office/document parsing. The WebUI rejects
# uploaded documents above this limit before adding them to the import tree.
# SCRAPEGOAT_SCRAPER_DOCUMENT_MAX_SIZE=1048576000

# -----------------------------------------------------------------------------
# WebUI Local Import Limits
# -----------------------------------------------------------------------------
# Maximum number of files in one upload/import session or virtual folder tree.
# Alias: SCRAPEGOAT_WEB_IMPORT_MAX_VIRTUAL_FOLDER_FILES
# SCRAPEGOAT_WEB_IMPORT_MAX_FILES=9999

# Maximum size in bytes for all staged files in one upload/import session.
# SCRAPEGOAT_WEB_IMPORT_MAX_TOTAL_SIZE_BYTES=2147483648

# Maximum size in bytes for a single uploaded file before archive extraction.
# SCRAPEGOAT_WEB_IMPORT_MAX_FILE_SIZE_BYTES=134217728

# Maximum number of files accepted from one archive.
# Alias: SCRAPEGOAT_WEB_IMPORT_MAX_ARCHIVE_FILES
# SCRAPEGOAT_WEB_IMPORT_MAX_ARCHIVE_ENTRIES=9999

# Maximum total uncompressed archive size in bytes.
# Alias: SCRAPEGOAT_WEB_IMPORT_MAX_ARCHIVE_UNCOMPRESSED_SIZE_BYTES
# SCRAPEGOAT_WEB_IMPORT_MAX_ARCHIVE_UNCOMPRESSED_BYTES=2147483648

# Maximum compressed archive upload size in bytes.
# SCRAPEGOAT_WEB_IMPORT_MAX_ARCHIVE_COMPRESSED_BYTES=536870912

# Optional alias that sets the same value as SCRAPEGOAT_SCRAPER_DOCUMENT_MAX_SIZE.
# SCRAPEGOAT_WEB_IMPORT_MAX_DOCUMENT_SIZE_BYTES=1048576000

# -----------------------------------------------------------------------------
# Telemetry (Optional)
# -----------------------------------------------------------------------------
# PostHog analytics API key. Leave empty to disable analytics.
# POSTHOG_API_KEY=

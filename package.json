{
  "name": "@midnightphreaker/scrapegoat",
  "version": "2.2.1",
  "description": "ScrapeGoat - MCP server for fetching, indexing, and searching documentation",
  "type": "module",
  "bin": {
    "scrapegoat": "dist/index.js"
  },
  "license": "MIT",
  "author": "phrk.org",
  "repository": {
    "type": "git",
    "url": "git+https://git.phrk.org/pub/scrapegoat.git"
  },
  "files": [
    "dist",
    "public",
    "db",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "prepare": "husky || true",
    "build": "vite build --config vite.config.web.ts && vite build",
    "start": "node --enable-source-maps dist/index.js",
    "cli": "node --enable-source-maps dist/index.js",
    "server": "node --enable-source-maps dist/index.ts",
    "web": "node --enable-source-maps dist/index.ts web",
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "vite-node --watch src/index.ts",
    "dev:web": "vite build --config vite.config.web.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src",
    "pretest:e2e": "npm run build",
    "test:e2e": "vitest run test",
    "evaluate:search": "promptfoo eval -c tests/search-eval/promptfoo.yaml",
    "test:live": "vitest run --exclude= test/html-pipeline-live-e2e.test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix",
    "typecheck": "npx tsc --noEmit",
    "typecheck:build": "npx tsc --noEmit --project tsconfig.build.json",
    "format": "biome format . --write",
    "postinstall": "echo 'Skipping Playwright browser install. See README.md for details.'"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.8",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.3.0",
    "@joplin/turndown-plugin-gfm": "^1.0.64",
    "@kitajs/html": "^4.2.13",
    "@kitajs/ts-html-plugin": "^4.1.4",
    "@kreuzberg/node": "^4.4.6",
    "@langchain/aws": "^1.3.2",
    "@langchain/core": "^1.1.36",
    "@langchain/google-genai": "^2.1.25",
    "@langchain/google-vertexai": "^2.1.25",
    "@langchain/openai": "^1.2.13",
    "@langchain/textsplitters": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@toon-format/toon": "^2.1.0",
    "@trpc/client": "^11.13.4",
    "@trpc/server": "^11.4.4",
    "@types/yargs": "^17.0.35",
    "alpinejs": "^3.15.8",
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "cheerio": "^1.2.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "env-paths": "^3.0.0",
    "fastify": "^5.8.2",
    "flowbite": "^4.0.1",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "header-generator": "^2.1.81",
    "htmx.org": "^2.0.8",
    "iconv-lite": "^0.7.2",
    "idiomorph": "^0.7.4",
    "jose": "^6.2.1",
    "jsdom": "^27.4.0",
    "langchain": "^1.2.32",
    "mime": "^4.1.0",
    "minimatch": "^10.2.4",
    "playwright": "^1.58.2",
    "posthog-node": "^5.21.2",
    "pg": "^8.13.1",
    "psl": "^1.15.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "semver": "^7.7.4",
    "superjson": "^2.2.6",
    "tar": "^7.5.11",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2",
    "turndown": "^7.2.2",
    "unified": "^11.0.5",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0",
    "yauzl": "^3.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/alpinejs": "^3.13.11",
    "@types/alpinejs__collapse": "~3.13.4",
    "@types/archiver": "^7.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/lint-staged": "~13.3.0",
    "@types/node": "^24.12.0",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.11.10",
    "@types/psl": "^1.1.3",
    "@types/semver": "^7.7.1",
    "@types/tar": "^6.1.13",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@types/yauzl": "^2.10.3",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.27",
    "domhandler": "^6.0.1",
    "flowbite-typography": "^1.0.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "memfs": "^4.56.11",
    "msw": "^2.12.10",
    "nock": "^14.0.11",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "promptfoo": "^0.120.19",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-node": "^5.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "npm": "10.9.3"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md}": [
      "biome check --write --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
